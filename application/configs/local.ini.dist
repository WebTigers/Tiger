; Copy to local.ini (gitignored) for per-deploy secrets / environment values.
; local.ini merges LAST, so it wins over application.ini and core.ini.
; Keep secrets OUT of application.ini — they belong here, uncommitted.
[production]
; tiger.db.secret  = "myapp/rds/prod"     ; AWS Secrets Manager key name
; tiger.aws.region = "us-east-1"

[development : production]
; tiger.db.secret  = "myapp/rds/dev"
