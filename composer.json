{
    "name": "webtigers/tiger",
    "description": "Tiger skeleton — scaffold for a 1-click SaaS app on the Tiger platform",
    "type": "project",
    "license": "(MIT AND BSD-3-Clause)",
    "require": {
        "php": ">=8.1",
        "webtigers/tiger-core": "@dev"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../tiger-core",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-0": {
            "App_": "library/"
        },
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
