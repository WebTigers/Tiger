{
    "name": "webtigers/tiger",
    "description": "Tiger skeleton — scaffold for a 1-click SaaS app on the Tiger platform",
    "type": "project",
    "license": "BSD-3-Clause",
    "require": {
        "php": ">=8.1",
        "webtigers/tiger-core": ">=0.1.0-beta <1.0.0"
    },
    "autoload": {
        "psr-0": {
            "App_": "library/"
        },
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
