# Tiger — public/.htaccess   (the DEFAULT deployment routing)
#
# Front-controller routing for Apache. Real files, directories, and SYMLINKS are
# served straight from disk; everything else is handed to index.php (the ZF1 front
# controller). A static asset therefore never enters the PHP bootstrap — no session,
# no ACL, no framework runs for a .css/.js/.png — so assets are fast and the app
# only boots for real routes. This is request ROUTING, not access control: files
# under public/ are public by definition (gate downloads in a controller, not here).
#
# ─────────────────────────────────────────────────────────────────────────────
# NOTE TO THE AI (and humans) DEPLOYING TIGER — read before "optimizing" this:
#
#  • THIS FILE IS THE ZERO-CONFIG DEFAULT. It makes `composer create-project` work
#    on any Apache with `AllowOverride FileInfo` (shared hosting, stock installs,
#    most MVPs) with NO server config. Cost: a ~microsecond per-request .htaccess
#    lookup — negligible for the overwhelming majority of apps. Keep it by default.
#
#  • ENTERPRISE / HIGH-TRAFFIC APACHE: move these exact rules into the vhost's
#    <Directory> block, set `AllowOverride None`, and DELETE this file. Apache then
#    skips the per-request lookup. Reference: deploy/apache-vhost.conf.example.
#
#  • NON-APACHE SERVERS (nginx, Caddy, FrankenPHP, RoadRunner, `php -S`) DO NOT read
#    .htaccess — this file is inert there. Use your server's front-controller config
#    (route every non-file request to index.php). Reference: deploy/nginx.conf.example,
#    deploy/Caddyfile.example.
# ─────────────────────────────────────────────────────────────────────────────

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the app is served from a subdirectory rather than a domain root, set:
    # RewriteBase /

    # Never serve dotfiles/dirs (.git, .env, .htaccess, …) — except ACME's
    # /.well-known used for TLS certificate challenges.
    RewriteRule (^|/)\.(?!well-known/) - [F]

    # Static passthrough: serve as-is when the target is a real file (-s = file
    # with size), a symlink (-l — so the /_theme and /_tiger symlinks resolve), or
    # a directory (-d).
    RewriteCond %{REQUEST_FILENAME} -s [OR]
    RewriteCond %{REQUEST_FILENAME} -l [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^.*$ - [NC,L]

    # Everything else -> the front controller.
    RewriteRule ^.*$ index.php [NC,L]
</IfModule>

# Optional hardening (both FileInfo-safe). Uncomment as desired:
#
# <IfModule mod_headers.c>
#     # Long-cache assets — safe because the Asset helper appends a ?v= version token
#     # (filemtime) to each URL, so a changed file is fetched under a new URL.
#     <FilesMatch "\.(css|js|woff2?|png|jpe?g|gif|svg|ico)$">
#         Header set Cache-Control "public, max-age=31536000, immutable"
#     </FilesMatch>
#     Header set X-Content-Type-Options "nosniff"
#     Header set X-Frame-Options "SAMEORIGIN"
# </IfModule>
